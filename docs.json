      {
        "tab": "CLI",
        "groups": [
          {
            "group": "概述",
            "pages": [
              "en/cli/index"
            ]
          },
          {
            "group": "快速入门",
            "pages": [
              "en/cli/quick-start/installation",
              "en/cli/quick-start/get-api-key-and-log-in",
