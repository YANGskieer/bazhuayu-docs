  "redirects": [
    {
      "source": "/en/mcp/intro",
      "destination": "/en/mcp/index"
    }
  ],
  "footer": {
    "socials": {
      "twitter": "https://twitter.com/octoparse",
      "github": "https://github.com/octoparse",
      "linkedin": "https://linkedin.com/company/octoparse"
    }
  },
  "api": {
    "openapi": "en/api-reference/task-analytics/openapi.json",
    "mdx": {
      "server": "https://openapi.bazhuayu.com"
    },
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript",
        "typescript",
        "go",
        "java",
        "php",
        "ruby",
        "csharp",
        "kotlin",
        "rust"
      ],
      "defaults": "all",
      "prefill": true,
      "autogenerate": true
    }
  },
  "styling": {
    "css": "style.css"
  },
  "seo": {
    "metatags": {
      "og:image": "https://www.octoparse.com/docs/og-image.png",
      "twitter:card": "summary_large_image"
    },
    "indexing": "navigable"
  }
}
