{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Octoparse Docs",
  "colors": {
    "primary": "#0D47A1",
    "light": "#1565C0",
    "dark": "#0D47A1"
  },
  "favicon": "/assets/favicon.svg",
  "logo": {
    "light": "/assets/logo.png",
    "dark": "/assets/logo.png"
  },
  "navigation": {
    "languages": [
      {
        "language": "cn",
        "default": true,
