            ]
          },
          {
            "group": "平台对接",
            "pages": [
              "en/mcp/integrations/coze",
              "en/mcp/integrations/dify",
              "en/mcp/integrations/qclaw",
              "en/mcp/integrations/wecom"
            ]
          },
          {
            "group": "工具参考",
            "pages": [
              "en/mcp/search-templates",
